#!/bin/sh
# audio_cap.sh - Pure shell audio capture tool

# Configuration - User directories only
AUDIO_DIR="$HOME/.audio_captures"
mkdir -p "$AUDIO_DIR" 2>/dev/null

# Colors for output (optional)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Root prevention
if [ "$(id -u)" -eq 0 ]; then
    echo "${RED}Error: This script must NOT be run as root${NC}" >&2
    echo "Run as normal user: ./audio_cap.sh" >&2
    exit 1
fi

# Check if we can write to user directory
if [ ! -w "$AUDIO_DIR" ]; then
    echo "${RED}Error: Cannot write to $AUDIO_DIR${NC}" >&2
    exit 1
fi

# Check for required tools
check_deps() {
    missing=""
    command -v arecord >/dev/null 2>&1 || missing="$missing arecord"
    command -v ffmpeg >/dev/null 2>&1 || missing="$missing ffmpeg"
    
    if [ -n "$missing" ]; then
        echo "${YELLOW}Warning: Missing tools:$missing${NC}" >&2
        echo "Install with: sudo apt install alsa-utils ffmpeg" >&2
        return 1
    fi
    return 0
}

# Record from microphone
record_mic() {
    duration="$1"
    timestamp=$(date +%Y%m%d_%H%M%S)
    filename="mic_$timestamp.wav"
    filepath="$AUDIO_DIR/$filename"
    
    echo "${GREEN}Recording microphone to: $filepath${NC}"
    
    if [ -n "$duration" ] && [ "$duration" -gt 0 ] 2>/dev/null; then
        echo "Recording for $duration seconds..."
        arecord -q -f cd -t wav -d "$duration" "$filepath"
    else
        echo "Recording until Ctrl+C..."
        arecord -q -f cd -t wav "$filepath"
    fi
    
    if [ -f "$filepath" ] && [ -s "$filepath" ]; then
        size=$(du -h "$filepath" | cut -f1)
        echo "${GREEN}✓ Saved: $filename ($size)${NC}"
    else
        echo "${RED}✗ Recording failed${NC}" >&2
        rm -f "$filepath"
        return 1
    fi
}

# Record system audio (what you hear)
record_system() {
    duration="$1"
    timestamp=$(date +%Y%m%d_%H%M%S)
    filename="system_$timestamp.wav"
    filepath="$AUDIO_DIR/$filename"
    
    echo "${GREEN}Recording system audio to: $filepath${NC}"
    
    # Try different methods for system audio capture
    if command -v parec >/dev/null 2>&1; then
        # PulseAudio method
        if [ -n "$duration" ] && [ "$duration" -gt 0 ] 2>/dev/null; then
            timeout "$duration" parec --record --format=s16le --rate=44100 --channels=2 | \
                sox -t raw -r 44100 -e signed -b 16 -c 2 - "$filepath" 2>/dev/null
        else
            parec --record --format=s16le --rate=44100 --channels=2 | \
                sox -t raw -r 44100 -e signed -b 16 -c 2 - "$filepath" 2>/dev/null &
            pid=$!
            echo "Recording... Press Enter to stop"
            read dummy
            kill $pid 2>/dev/null
        fi
    elif command -v ffmpeg >/dev/null 2>&1; then
        # FFmpeg method
        if [ -n "$duration" ] && [ "$duration" -gt 0 ] 2>/dev/null; then
            ffmpeg -f pulse -i default -t "$duration" -acodec pcm_s16le "$filepath" -y 2>/dev/null
        else
            ffmpeg -f pulse -i default -acodec pcm_s16le "$filepath" -y 2>/dev/null &
            pid=$!
            echo "Recording... Press Enter to stop"
            read dummy
            kill $pid 2>/dev/null
        fi
    else
        echo "${RED}Error: No system audio capture method available${NC}" >&2
        return 1
    fi
    
    if [ -f "$filepath" ] && [ -s "$filepath" ]; then
        size=$(du -h "$filepath" | cut -f1)
        echo "${GREEN}✓ Saved: $filename ($size)${NC}"
    fi
}

# List recordings
list_recordings() {
    if [ -z "$(ls -A "$AUDIO_DIR" 2>/dev/null)" ]; then
        echo "${YELLOW}No recordings found in $AUDIO_DIR${NC}"
        return
    fi
    
    echo "${GREEN}Recordings in $AUDIO_DIR:${NC}"
    echo "----------------------------------------"
    ls -lh "$AUDIO_DIR" | awk '{print $9 " (" $5 ")"}' | grep -E '\.(wav|mp3)$' || echo "No audio files"
    echo "----------------------------------------"
    echo "Total: $(find "$AUDIO_DIR" -name "*.wav" -o -name "*.mp3" 2>/dev/null | wc -l) files"
}

# Play a recording
play_recording() {
    name="$1"
    
    # If no name provided, show list
    if [ -z "$name" ]; then
        list_recordings
        echo ""
        echo "Usage: $0 play <filename>"
        return 1
    fi
    
    # Find file (allow partial matching)
    filepath=$(find "$AUDIO_DIR" -name "*$name*" -type f 2>/dev/null | head -1)
    
    if [ -z "$filepath" ]; then
        echo "${RED}Error: No recording matching '$name' found${NC}" >&2
        list_recordings
        return 1
    fi
    
    echo "${GREEN}Playing: $(basename "$filepath")${NC}"
    
    # Try different players
    if command -v aplay >/dev/null 2>&1; then
        aplay "$filepath"
    elif command -v play >/dev/null 2>&1; then
        play "$filepath"
    elif command -v ffplay >/dev/null 2>&1; then
        ffplay -nodisp -autoexit "$filepath"
    else
        echo "${RED}Error: No audio player found${NC}" >&2
        return 1
    fi
}

# Delete recordings
delete_recording() {
    name="$1"
    
    if [ -z "$name" ]; then
        list_recordings
        echo ""
        echo "Usage: $0 delete <filename>"
        echo "Use 'all' to delete all recordings"
        return 1
    fi
    
    if [ "$name" = "all" ]; then
        echo -n "${YELLOW}Delete ALL recordings? (y/N): ${NC}"
        read answer
        if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
            rm -f "$AUDIO_DIR"/*.wav "$AUDIO_DIR"/*.mp3 2>/dev/null
            echo "${GREEN}✓ All recordings deleted${NC}"
        else
            echo "Cancelled"
        fi
        return
    fi
    
    # Find and delete
    filepath=$(find "$AUDIO_DIR" -name "*$name*" -type f 2>/dev/null | head -1)
    
    if [ -z "$filepath" ]; then
        echo "${RED}Error: No recording matching '$name' found${NC}" >&2
        return 1
    fi
    
    echo -n "Delete $(basename "$filepath")? (y/N): "
    read answer
    if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
        rm "$filepath"
        echo "${GREEN}✓ Deleted${NC}"
    else
        echo "Cancelled"
    fi
}

# Show status/info
show_info() {
    echo "${GREEN}Audio Capture Tool${NC}"
    echo "=================="
    echo "User: $USER (UID: $(id -u))"
    echo "Storage: $AUDIO_DIR"
    echo "Free space: $(df -h "$AUDIO_DIR" | tail -1 | awk '{print $4}')"
    echo ""
    echo "Recordings:"
    list_recordings
    echo ""
    
    # Check available capture methods
    echo "Available capture methods:"
    command -v arecord >/dev/null && echo "  ✓ arecord (microphone)"
    command -v parec >/dev/null && echo "  ✓ parec (system audio)"
    command -v ffmpeg >/dev/null && echo "  ✓ ffmpeg (system audio)"
    command -v sox >/dev/null && echo "  ✓ sox (audio processing)"
    echo ""
    
    echo "Disk usage: $(du -sh "$AUDIO_DIR" 2>/dev/null | cut -f1 || echo "0")"
}

# Main menu
show_menu() {
    echo ""
    echo "${GREEN}Audio Capture Tool${NC}"
    echo "=================="
    echo "1) Record microphone"
    echo "2) Record system audio"
    echo "3) List recordings"
    echo "4) Play recording"
    echo "5) Delete recording"
    echo "6) Show info"
    echo "q) Quit"
    echo ""
    echo -n "Choose option: "
}

# Main script
main() {
    # Check dependencies if needed
    case "$1" in
        mic|system|list|play|delete|info|status)
            # Commands that may need deps
            check_deps
            ;;
    esac
    
    case "$1" in
        mic)
            record_mic "$2"
            ;;
        system)
            record_system "$2"
            ;;
        list)
            list_recordings
            ;;
        play)
            play_recording "$2"
            ;;
        delete)
            delete_recording "$2"
            ;;
        info|status)
            show_info
            ;;
        interactive|"")
            # Interactive mode
            while true; do
                show_menu
                read choice
                case "$choice" in
                    1) record_mic "" ;;
                    2) record_system "" ;;
                    3) list_recordings ;;
                    4) 
                        echo -n "Enter filename (or partial): "
                        read name
                        play_recording "$name"
                        ;;
                    5)
                        echo -n "Enter filename (or 'all'): "
                        read name
                        delete_recording "$name"
                        ;;
                    6) show_info ;;
                    q|Q) 
                        echo "Goodbye!"
                        exit 0
                        ;;
                    *) echo "Invalid option" ;;
                esac
                echo ""
                echo "Press Enter to continue..."
                read dummy
            done
            ;;
        *)
            echo "Usage: $0 [command] [options]"
            echo ""
            echo "Commands:"
            echo "  mic [seconds]   - Record from microphone"
            echo "  system [seconds] - Record system audio"
            echo "  list            - List all recordings"
            echo "  play <name>     - Play a recording"
            echo "  delete <name>   - Delete a recording"
            echo "  info            - Show tool information"
            echo "  interactive     - Run in interactive mode"
            echo ""
            echo "Examples:"
            echo "  $0 mic           # Record microphone until Ctrl+C"
            echo "  $0 mic 10        # Record microphone for 10 seconds"
            echo "  $0 play meeting  # Play recording containing 'meeting'"
            echo "  $0 interactive   # Launch interactive menu"
            echo ""
            echo "All recordings saved to: $AUDIO_DIR"
            exit 1
            ;;
    esac
}

# Run main with all arguments
main "$@"
